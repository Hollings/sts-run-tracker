# Docker Compose environment variables for StS2 Tracker
#
# Copy this file to .env and fill in your paths:
#   cp .env.example .env
#
# The backend auto-discovers save paths when running outside Docker,
# but Docker needs explicit volume mount paths.

# Path to the game's save directory (contains modded/ and profile1/ subdirectories)
# Find yours at: %APPDATA%\SlayTheSpire2\steam\<your_steam64_id>
STS2_SAVES_PATH=C:/Users/YOUR_USER/AppData/Roaming/SlayTheSpire2/steam/YOUR_STEAM64_ID
